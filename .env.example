# ===================================================================
# ENVIRONMENT CONFIGURATION - TYPESCRIPT VERSION
# ===================================================================

# Platform: webchat, telegram, instagram, facebook, dhai
PLATFORM=webchat

# File data testing (di folder assets/json atau assets/xlsx)
FILENAME=testdhai.json

# Tester info
TESTER_NAME=Nama Penguji
GREETING=Halo

# ===================================================================
# WEBCHAT CONFIGURATION
# ===================================================================
TARGET_URL=https://your-webchat-url.com

# ===================================================================
# TELEGRAM CONFIGURATION
# ===================================================================
TARGET_BOT_USERNAME=@your_bot_username
API_ID=your_telegram_api_id
API_HASH=your_telegram_api_hash
TELEGRAM_SESSION=your_telegram_session_string

# ===================================================================
# INSTAGRAM CONFIGURATION
# ===================================================================
TARGET_USERNAME=target_instagram_username

# ===================================================================
# FACEBOOK CONFIGURATION
# ===================================================================
TARGET_FANPAGE_ID=your_fanpage_id

# ===================================================================
# DHAI CONFIGURATION
# ===================================================================
DHAI_TARGET_URL=https://your-dhai-url.com

# ===================================================================
# DHAI WAKE-UP WORD CONFIGURATION (dengan TTS)
# ===================================================================
DHAI_WAKEUP_URL=https://your-dhai-wakeup-url.com
DHAI_WAKE_WORD=halo luna
