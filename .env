# =================================================================
# ==           KONFIGURASI DEFAULT UNTUK PENGUJIAN LOKAL         ==
# =================================================================
# File konfigurasi untuk testing Facebook chatbot

# --- PENGATURAN UTAMA ---
# Platform yang akan diuji. Pilihan: webchat, webchat-v3, telegram, instagram, facebook, dhai
PLATFORM=webchat
HEADLESS=true
    
# Nama file data uji (mendukung CSV, XLSX, atau JSON)
FILENAME=Testing.xlsx

# Nama penguji yang akan muncul di laporan
TESTER_NAME=Cik luna   
# Sapaan awal untuk memulai percakapan dengan bot
GREETING="Haloo"
GREETING_2="English"

# --- PENGATURAN SPESIFIK PLATFORM ---

# --- Pengaturan Webchat ---
TARGET_URL="https://chat.botika.online/EJUnkrW"
WEBCHAT_V3_TARGET_URL="https://chat.botika.online/v3/mk6YoYD"

# Kredensial untuk Pre-Chat Form (Webchat & Webchat V3)
WEBCHAT_NAME="Tester Automation"
WEBCHAT_EMAIL="tester@example.com"
WEBCHAT_PHONE="081234567890"

# Untuk Facebook
TARGET_FANPAGE_ID="114552848299710"

# --- Pengaturan Telegram ---
TARGET_BOT_USERNAME="TestingNewIntegrasiBot"
API_ID="29690079"
API_HASH="695b27c3cb9721cf522d99b871de5912"
# TELEGRAM_SESSION akan otomatis di-generate dan disimpan di session/session-telegram.json
# Tidak perlu set manual lagi, cukup API_ID dan API_HASH saja

# --- Pengaturan Instagram ---
TARGET_USERNAME="ahmadnurbrasta2.2"

# --- Pengaturan DHAI ---
DHAI_TARGET_URL="https://client.botika.online/virtual-avatar-pln-icon/"

# --- Pengaturan DHAI Wake-up Word (dengan TTS) ---
DHAI_WAKEUP_URL="https://client.botika.online/virtual-avatar-pln-icon/"
